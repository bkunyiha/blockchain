\begin{MintedVerbatim}[commandchars=\\\{\}]
\PYG{c+c1}{\PYGZsh{} Stop all services (keeps volumes)}
docker\PYG{+w}{ }compose\PYG{+w}{ }down

\PYG{c+c1}{\PYGZsh{} Stop and remove volumes (deletes all data)}
docker\PYG{+w}{ }compose\PYG{+w}{ }down\PYG{+w}{ }\PYGZhy{}v

\PYG{c+c1}{\PYGZsh{} View volumes before deletion}
docker\PYG{+w}{ }volume\PYG{+w}{ }ls\PYG{+w}{ }\PYG{p}{|}\PYG{+w}{ }grep\PYG{+w}{ }blockchain
\end{MintedVerbatim}
